@model List<MediaViewModel>

<div class="d-flex align-items-center justify-content-between mb-4">
    <h2 class="page-title mb-0">Каталог фільмів</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Додати медіа
    </a>
</div>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100 surface-card media-card">
                <div class="card-body">
                    <h5 class="card-title fw-bold">@item.Title</h5>
                    <p class="card-text text-muted mb-3">
                        <i class="bi bi-calendar3 me-1"></i> Рік: @item.ReleaseYear
                    </p>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary">Детальніше</a>
                </div>
            </div>
        </div>
    }
</div>