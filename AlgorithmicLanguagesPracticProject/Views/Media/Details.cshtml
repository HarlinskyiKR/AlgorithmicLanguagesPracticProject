@model MediaDetailsViewModel

@{
    ViewBag.Title = Model.Title + " - Деталі";
}

<div class="card surface-card p-4">
    <h1 class="mb-2">@Model.Title</h1>
    <p class="lead text-muted mb-4">@Model.Description</p>

    <div class="row mb-4">
        <div class="col-md-4 mb-3 mb-md-0">
            <img src="@Model.PosterUrl" alt="Постер @Model.Title" class="img-fluid rounded" />
        </div>
        <div class="col-md-8">
            <dl class="row mb-0">
                <dt class="col-sm-4">Жанр</dt>
                <dd class="col-sm-8">@Model.GenreName</dd>

                <dt class="col-sm-4">Країна</dt>
                <dd class="col-sm-8">@Model.Country</dd>

                <dt class="col-sm-4">Режисери</dt>
                <dd class="col-sm-8">@Model.Directors</dd>

                <dt class="col-sm-4">Актори</dt>
                <dd class="col-sm-8">@Model.Actors</dd>

                <dt class="col-sm-4">Рейтинг</dt>
                <dd class="col-sm-8">
                    <i class="bi bi-star-fill text-warning me-1"></i> @Model.Rating.ToString("0.0")
                </dd>

                <dt class="col-sm-4">Рік випуску</dt>
                <dd class="col-sm-8">@Model.ReleaseYear</dd>
            </dl>
        </div>
    </div>

    <div class="ratio ratio-16x9 mb-4">
        <iframe src="@Model.PlayerIframeUrl" title="Плеєр @Model.Title" allowfullscreen></iframe>
    </div>

    <h4 class="mb-3">Коментарі (@Model.Comments.Count)</h4>
    @foreach (var comment in Model.Comments)
    {
        <div class="comment-box p-3 mb-2">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <small class="text-muted d-block">@comment.CreatedAt.ToShortDateString()</small>
                    <small class="fw-semibold">@comment.Username</small>
                </div>
            </div>
            <p class="mb-0 mt-2">@comment.Content</p>
        </div>
    }

    @if (User.Identity?.IsAuthenticated ?? false)
    {
        <form asp-action="AddComment" method="post" class="mt-4">
            @Html.AntiForgeryToken()
            <input type="hidden" name="MediaId" value="@Model.Id" />
            <textarea name="Content" class="form-control" rows="4" placeholder="Ваш коментар..."></textarea>
            <button type="submit" class="btn btn-primary mt-2">Додати коментар</button>
        </form>
    }
</div>