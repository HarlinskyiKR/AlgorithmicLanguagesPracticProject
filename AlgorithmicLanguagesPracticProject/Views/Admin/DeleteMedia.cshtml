@model MediaDeleteViewModel
@{
    ViewData["Title"] = "Видалення медіа";
}

<h2 class="page-title text-danger">Видалення медіа</h2>

<div class="card surface-card p-4">
    <p class="mb-1">Ви дійсно хочете видалити цей запис?</p>
    <h4 class="mb-3">ID:@Model.Id | @Model.Title</h4>
    <form asp-action="DeleteMediaConfirmed" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-danger">Так, видалити</button>
        <a asp-action="Media" class="btn btn-outline-secondary">Скасувати</a>
    </form>
</div>
