@model List<MediaViewModel>

@{
    ViewBag.Title = "Керування медіа";
}

@await Html.PartialAsync("_PageTitle", new PageTitleViewModel
{
    Title = "Керування медіа",
    AddAction = "CreateMedia"
})

<div class="table-wrap">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>ID</th>
                <th>Назва</th>
                <th class="text-end">Дії</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var m in Model)
            {
                <tr>
                    <td>@m.Id</td>
                    <td class="fw-semibold">@m.Title</td>
                    <td class="text-end">
                        <a asp-action="EditMedia" asp-route-id="@m.Id" class="btn btn-sm btn-outline-warning">Редагувати</a>
                        <a asp-action="DeleteMedia" asp-route-id="@m.Id" class="btn btn-sm btn-outline-danger">Видалити</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>