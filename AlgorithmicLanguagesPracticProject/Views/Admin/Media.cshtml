@model List<MediaViewModel>

<div class="d-flex justify-content-between mb-3">
    <h2 class="page-title mb-0">Керування медіа</h2>
    <a asp-controller="Media" asp-action="Create" class="btn btn-success">Додати нове</a>
</div>

<div class="table-wrap">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>ID</th>
                <th>Назва</th>
                <th class="text-end">Дії</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var m in Model)
            {
                <tr>
                    <td>@m.Id</td>
                    <td class="fw-semibold">@m.Title</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@m.Id" class="btn btn-sm btn-outline-warning">Редагувати</a>
                        <a asp-action="Delete" asp-route-id="@m.Id" class="btn btn-sm btn-outline-danger">Видалити</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>