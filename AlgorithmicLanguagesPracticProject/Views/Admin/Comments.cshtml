@model List<AdminCommentViewModel>

@{
    ViewBag.Title = "Керування коментарями";
}
<div class="d-flex justify-content-between mb-3">
    <h2 class="page-title">Керування коментарями</h2>
</div>

<div class="table-wrap">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>ID</th>
                <th>Текст</th>
                <th>Користувач</th>
                <th>MediaId</th>
                <th>Дата</th>
                <th class="text-end">Дія</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var comment in Model)
            {
                <tr>
                    <td>@comment.Id</td>
                    <td>@comment.Content</td>
                    <td>@comment.Username</td>
                    <td>@comment.MediaId</td>
                    <td>@comment.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td class="text-end">
                        <form asp-action="DeleteComment" asp-route-id="@comment.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">Видалити</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
