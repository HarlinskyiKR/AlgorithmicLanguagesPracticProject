@model UserProfileViewModel

@{
    ViewBag.Title = "Профіль";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h2 class="page-title mb-0">Профіль</h2>
</div>


<div class="card surface-card">
    <div class="card-body">
        <h4 class="card-title mb-3">@Model.Username</h4>
        <p class="card-text"><strong>Email:</strong> @Model.Email</p>
        <p class="card-text"><strong>Роль:</strong> Model.Role</p>
    </div>
